---
import { siteConfig } from '../data/site';

const registrationHref = siteConfig.registrationUrl || '#registro';
const informativeGroupHref = siteConfig.informativeGroupUrl || '#grupo-informativo';
const isExternalRegistration = siteConfig.registrationUrl.startsWith('http');
const isExternalGroup = siteConfig.informativeGroupUrl.startsWith('http');
---

<footer class="relative overflow-hidden border-t border-white/5 bg-page" aria-label="Pie de página">
	<div class="footer-orb footer-orb-left" aria-hidden="true"></div>
	<div class="footer-orb footer-orb-right" aria-hidden="true"></div>

	<div class="relative mx-auto grid max-w-7xl gap-12 px-5 py-16 sm:px-8 lg:grid-cols-[minmax(0,0.9fr)_minmax(20rem,0.7fr)] lg:px-14 lg:py-24">
		<div class="max-w-2xl">
			<h2 class="max-w-xl text-3xl font-bold uppercase leading-tight tracking-tight text-text-muted sm:text-4xl">
				Sé parte del evento pionero de data para la ciudad de Arequipa
			</h2>

			<div class="mt-8 flex flex-col gap-4 sm:flex-row">
				<a
					href={registrationHref}
					target={isExternalRegistration ? '_blank' : undefined}
					rel={isExternalRegistration ? 'noopener noreferrer' : undefined}
					class="inline-flex items-center justify-center gap-2 bg-primary px-7 py-4 text-lg font-semibold text-white shadow-glow transition hover:bg-primary-hover focus-visible:outline-2 focus-visible:outline-offset-4 focus-visible:outline-accent"
				>
					Quiero ser parte
					<span aria-hidden="true">→</span>
				</a>
				<a
					href={informativeGroupHref}
					target={isExternalGroup ? '_blank' : undefined}
					rel={isExternalGroup ? 'noopener noreferrer' : undefined}
					class="inline-flex items-center justify-center gap-2 border border-accent px-7 py-4 text-lg font-semibold text-accent transition hover:bg-accent/10 focus-visible:outline-2 focus-visible:outline-offset-4 focus-visible:outline-accent"
				>
					Grupo informativo
					<span aria-hidden="true">▣</span>
				</a>
			</div>

			<img
				src={siteConfig.logoUrl}
				alt="Arequipa Data Fest 2026"
				width="449"
				height="129"
				class="mt-12 h-auto w-56 sm:w-72"
				loading="lazy"
			/>
		</div>

		<svg class="footer-network self-end" viewBox="0 0 640 420" role="presentation" aria-hidden="true">
			<defs>
				<linearGradient id="network-gradient" x1="0" x2="1" y1="1" y2="0">
					<stop stop-color="#8f36e7" />
					<stop offset="1" stop-color="#6eeaff" />
				</linearGradient>
				<filter id="network-glow"><feGaussianBlur stdDeviation="3" /></filter>
			</defs>
			<path class="network-mountain" d="M24 350 168 238l74 74 87-147 72 106 89-180 126 259" />
			<path class="network-line" d="M28 350c125-89 183-42 274-126S472 252 626 116" />
			<path class="network-line" d="M45 378c112-30 171-114 270-89s167 73 299-27" />
			<path class="network-line" d="M116 330c86-76 159-28 233-126 84-110 171-41 263-128" />
			<path class="network-smoke" d="M478 92c-32-24 20-49-7-76-24-24 11-47 24-68" />
			{[
				[24, 350], [168, 238], [242, 312], [329, 165], [401, 271], [490, 91], [616, 350], [302, 224], [472, 252],
			].map(([cx, cy]) => <circle class="network-node" cx={cx} cy={cy} r="10" />)}
		</svg>
	</div>

	<p class="relative mx-auto max-w-7xl px-5 pb-8 text-center text-sm font-semibold tracking-wide text-accent/85 sm:px-8 lg:px-14">
		© 2026 Arequipa Data Fest. Todos los derechos reservados.
	</p>
</footer>
